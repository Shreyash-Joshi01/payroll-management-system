{
  "name": "payroll-management-system",
  "version": "1.0.0",
  "type": "module",
  "description": "A full-stack payroll management system",
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "frontend": "cd payroll-frontend && npm start",
    "backend": "cd Backend && npm run dev",
    "install-all": "npm install && cd payroll-frontend && npm install && cd ../Backend && npm install",
    "vercel-build": "cd payroll-frontend && npm install && npm run build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "nodemailer": "^8.0.2",
    "react-datepicker": "^8.3.0",
    "react-icons": "^5.5.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
