{
  "version": 2,
  "builds": [
    {
      "src": "payroll-frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    },
    {
      "src": "Backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/Backend/server.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/payroll-frontend/$1"
    }
  ]
}
